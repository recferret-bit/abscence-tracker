# --- Postgres -------------------------------------------------------------
POSTGRES_USER=absence
POSTGRES_PASSWORD=absence
POSTGRES_DB=absence
POSTGRES_PORT=5432

# --- Backend (NestJS) -----------------------------------------------------
BACKEND_PORT=4000

# Generate a long random string for production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=12h

# Initial admin user, created/updated by the seed script on every backend start
ADMIN_EMAIL=admin@finharbor.com
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin User

# Where the SPA is served from (used for CORS allow-list)
FRONTEND_ORIGIN=http://localhost:3001

# Set to "true" when serving over HTTPS so the auth cookie is marked Secure
COOKIE_SECURE=false

# --- Frontend (nginx) -----------------------------------------------------
FRONTEND_PORT=3001
