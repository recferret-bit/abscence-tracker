# Postgres connection string used by Prisma
DATABASE_URL="postgresql://absence:absence@localhost:5432/absence?schema=public"

# JWT signing
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="12h"

# Initial admin user, created/updated by `npm run prisma:seed`
ADMIN_EMAIL="admin@finharbor.com"
ADMIN_PASSWORD="admin"
ADMIN_NAME="Admin User"

# CORS / cookie
FRONTEND_ORIGIN="http://localhost:3000"
COOKIE_SECURE="false"

# HTTP
PORT="4000"
